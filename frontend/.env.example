# Copie para .env e preencha com os valores do seu ambiente.

# URL do backend (Render em produção). Em dev, deixe vazio para usar o proxy do Vite.
VITE_API_URL=http://localhost:3001/api

# Fallback opcional para rotas GET de leitura quando o backend primário estiver
# inacessível (ex.: /api servido pelas functions da Vercel). Vazio = desativado.
VITE_API_FALLBACK_URL=

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Feature flags
VITE_DIAGNOSTIC_HYPOTHESES_ENABLED=true
