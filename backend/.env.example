# Copie para .env e preencha com os valores do seu ambiente.

PORT=3001
FRONTEND_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3001

# OpenAI
OPENAI_API_KEY=
ANALYSIS_ENGINE=unified_ai
DIAGNOSTIC_HYPOTHESES_ENABLED=true
DIAGNOSTIC_MODEL=gpt-4o

# Enriquecimento por IA dos templates próprios (aliases/evidências/orientações
# por seção no momento de salvar). Vazio/true = ligado; 'false' desliga (cai na
# herança por similaridade com os oficiais). Requer supabase/user_templates_enrichment.sql.
TEMPLATE_ENRICHMENT_ENABLED=true
TEMPLATE_ENRICHMENT_MODEL=gpt-4o-mini
# Modelo da geração de protocolos de prescrição (Structured Outputs)
PROTOCOL_MODEL=gpt-4.1

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Rate limiting: 'supabase' (padrão, requer supabase/rate_limits.sql aplicado)
# ou 'memory' para forçar o fallback em memória por processo.
RATE_LIMIT_STORE=

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_WEBHOOK_URL=

# Notion (CMS editorial)
NOTION_API_KEY=
NOTION_TEMPLATES_DATA_SOURCE_ID=
NOTION_PROMPTS_DATA_SOURCE_ID=
NOTION_PRESCRIPTION_GUIDES_DATA_SOURCE_ID=
NOTION_CLINICAL_DRUGS_DATA_SOURCE_ID=

# Segredos das rotas administrativas de sincronização
TEMPLATE_SYNC_SECRET=
PROMPT_SYNC_SECRET=
PRESCRIPTION_GUIDES_SYNC_SECRET=
CLINICAL_DRUGS_SYNC_SECRET=
ADMIN_SYNC_SECRET=
NOTION_WEBHOOK_VERIFICATION_TOKEN=
# Automação de protocolos (preview/relatório e, na fase 2, escrita/polling).
# Fallback para ADMIN_SYNC_SECRET se vazio.
PROTOCOL_AUTOMATION_SECRET=
# Caminho opcional para substituir a lista de medicamentos (CSV). Padrão:
# backend/data/medicamentos_assis.csv (lista da Prefeitura de Assis, ~220 itens)
MEDICATION_DICTIONARY_PATH=

# Trial
PRO_TRIAL_DAYS=7
# Reengajamento de fim de trial (e-mail via Resend, direto por fetch).
# Sem RESEND_API_KEY, o lembrete falha silenciosamente (best-effort) e nada quebra.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Minha Anamnese <onboarding@resend.dev>
TRIAL_REMINDER_DAYS_BEFORE=2

# Afiliados: valor mínimo de saque (R$) e webhook de notificação de saque
# solicitado (ex.: n8n -> WhatsApp/e-mail). Vazios = padrão R$50 / sem notificação.
AFFILIATE_PAYOUT_MIN_AMOUNT=50
AFFILIATE_PAYOUT_WEBHOOK_URL=

# Segredo para assinar os links de baixa de saque enviados no WhatsApp.
# Se vazio, usa ADMIN_SYNC_SECRET. Sem nenhum dos dois, os links não são gerados
# (a notificação chega sem os botões e a baixa é feita pelo painel/endpoint admin).
PAYOUT_ACTION_SECRET=

# Limites de payload
JSON_BODY_LIMIT=1mb

# Debug (true/false)
DEBUG_AUTH=
DEBUG_BILLING=
